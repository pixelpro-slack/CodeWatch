  document.getElementById('cnt-high').textContent = counts.high;
  document.getElementById('cnt-medium').textContent = counts.medium;
  document.getElementById('cnt-low').textContent = counts.low;
  document.getElementById('cnt-info').textContent = counts.info;
  
  const vEl = document.getElementById('verdict-badge');
  vEl.className = 'verdict';
  if (review.verdict === 'APPROVE') { vEl.classList.add('verdict-approve'); vEl.textContent = '✓ APPROVE'; }
  else if (review.verdict === 'REQUEST_CHANGES') { vEl.classList.add('verdict-reject'); vEl.textContent = '✗ REQUEST CHANGES'; }
  else { vEl.classList.add('verdict-discuss'); vEl.textContent = '⚠ NEEDS DISCUSSION'; }
  
  document.getElementById('summary-bar').style.display = 'flex';
  document.getElementById('result-time').textContent = `${(ms/1000).toFixed(1)}s • score: ${review.score}/100`;
  
  const issueList = document.getElementById('issue-list');
  issueList.style.display = 'flex';
  issueList.innerHTML = '';
  
  if (review.summary) {
    const sumDiv = document.createElement('div');
    sumDiv.style.cssText = 'font-size:12px;color:var(--text2);padding:10px 14px;background:var(--bg3);border-radius:8px;margin-bottom:4px;line-height:1.6;border:1px solid var(--border)';
    sumDiv.innerHTML = `<span style="color:var(--accent2);font-size:10px;letter-spacing:.1em">SUMMARY</span><br>${review.summary}`;
    issueList.appendChild(sumDiv);
  }
  
  (review.issues || []).forEach((issue, idx) => {
    const sev = issue.severity.toLowerCase();
    const card = document.createElement('div');
    card.className = `issue-card ${sev}`;
    card.style.animationDelay = `${idx * 0.08}s`;
    card.innerHTML = `
      <div class="issue-header">
        <span class="severity-badge badge-${sev}">${issue.severity}</span>
        <span class="issue-title">${issue.title}</span>
        <span class="issue-location">${issue.location || ''}</span>
      </div>
      <div class="issue-desc">${issue.description}</div>
      ${issue.fix ? `<div class="issue-fix"><div class="issue-fix-label">RECOMMENDED FIX</div>${issue.fix}</div>` : ''}
    `;
    issueList.appendChild(card);
  });
  
  // Update stats
  state.reviews++;
  state.issues += (review.issues || []).length;
  state.critical += counts.critical;
  updateStats(review.score);
}

function updateStats(score) {
  document.getElementById('stat-reviews').textContent = state.reviews;
  document.getElementById('stat-issues').textContent = state.issues;
  document.getElementById('stat-critical').textContent = state.critical;
  document.getElementById('stat-score').textContent = score ? score : '—';
  document.getElementById('vuln-count').textContent = state.critical;
}

function saveHistory(review, lang, preview) {
  state.history.unshift({ review, lang, preview, ts: new Date() });
  document.getElementById('history-notif').style.display = 'block';
  renderHistory();
}

function renderHistory() {
  const list = document.getElementById('history-list');
  if (!state.history.length) return;
  list.innerHTML = state.history.map((h, i) => {
    const hasCritical = h.review.issues?.some(i => i.severity === 'CRITICAL');
    return `
    <div class="history-item" onclick="loadFromHistory(${i})">
      <div class="history-dot" style="background:${hasCritical ? 'var(--critical)' : 'var(--accent2)'}"></div>
      <div class="history-info">
        <div class="history-title">${h.lang} — ${h.preview}...</div>
        <div class="history-meta">${h.ts.toLocaleTimeString()} · ${h.review.issues?.length || 0} issues · ${h.review.verdict}</div>
      </div>
      <div class="history-score" style="color:${h.review.score > 70 ? 'var(--accent2)' : h.review.score > 40 ? 'var(--medium)' : 'var(--critical)'}">${h.review.score}</div>
    </div>`;
  }).join('');
}

function loadFromHistory(idx) {
  switchView('review');
}

// ---- SECURITY SCAN ----
async function runSecurityScan() {
  const code = document.getElementById('sec-input').value.trim();
  if (!code) {
    document.getElementById('sec-input').value = EXAMPLES.sqli.code;
    return;
  }
  
  const progress = document.getElementById('scan-progress');
  progress.style.width = '0%';
  
  // Animate progress
  let p = 0;
  const prog = setInterval(() => {
    p += Math.random() * 15;
    if (p > 85) { clearInterval(prog); }
    progress.style.width = Math.min(p, 85) + '%';
  }, 300);
  
  // Reset OWASP cards
  OWASP_CATEGORIES.forEach(c => {
    const card = document.getElementById(`owasp-${c.id}`);
    card.className = 'owasp-card';
    document.getElementById(`owasp-status-${c.id}`).textContent = '⟳ Scanning...';
    document.getElementById(`owasp-status-${c.id}`).className = 'owasp-status';
  });
  
  try {
    const res = await fetch('https://api.anthropic.com/v1/messages', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        model: 'claude-sonnet-4-6',
        max_tokens: 1000,
        messages: [{ role: 'user', content: `You are CodeWatch security scanner. Analyze this code for OWASP Top 10 vulnerabilities.

Return ONLY valid JSON (no markdown):
{
  "findings": {
    "A01": { "detected": true/false, "detail": "brief description or null" },
    "A02": { "detected": true/false, "detail": "..." },
    "A03": { "detected": true/false, "detail": "..." },
    "A04": { "detected": true/false, "detail": "..." },
    "A05": { "detected": true/false, "detail": "..." },
    "A06": { "detected": true/false, "detail": "..." },
    "A07": { "detected": true/false, "detail": "..." },
    "A08": { "detected": true/false, "detail": "..." },
    "A09": { "detected": true/false, "detail": "..." },
    "A10": { "detected": true/false, "detail": "..." }
  },
  "critical_count": 0,
  "summary": "One sentence overall security assessment"
}

Code:
${code}` }]
      })
    });
    
    clearInterval(prog);
    progress.style.width = '100%';
    
    const data = await res.json();
    const text = data.content?.[0]?.text || '';
    const clean = text.replace(/```json\n?/g,'').replace(/```\n?/g,'').trim();
    const result = JSON.parse(clean.match(/\{[\s\S]*\}/)?.[0] || clean);
    
    // Update OWASP cards
    Object.entries(result.findings || {}).forEach(([id, finding]) => {
      const card = document.getElementById(`owasp-${id}`);
      const statusEl = document.getElementById(`owasp-status-${id}`);
      if (finding.detected) {
        card.className = 'owasp-card detected';
        statusEl.className = 'owasp-status detected';
        statusEl.textContent = '⚠ ' + (finding.detail || 'Detected');
      } else {
        card.className = 'owasp-card clean';
        statusEl.className = 'owasp-status clean';
        statusEl.textContent = '✓ Clean';
      }
    });
    
    const findingsEl = document.getElementById('sec-findings');
    findingsEl.style.display = 'block';
    findingsEl.innerHTML = `
      <div style="background:var(--bg3);border:1px solid var(--border);border-radius:8px;padding:14px;">
        <div style="font-size:10px;color:var(--text3);letter-spacing:.1em;margin-bottom:6px">SECURITY ASSESSMENT</div>
        <div style="font-size:13px;color:var(--text);line-height:1.6">${result.summary || ''}</div>
      </div>`;
    
    state.critical += result.critical_count || 0;
    updateStats(null);
    
  } catch(err) {
    clearInterval(prog);
    progress.style.width = '0%';
    OWASP_CATEGORIES.forEach(c => {
      document.getElementById(`owasp-status-${c.id}`).textContent = '— Error';
    });
  }
}

// ---- ANALYZE ----
async function runAnalyze() {
  const prompt = document.getElementById('analyze-prompt').value.trim();
  const code = document.getElementById('analyze-code').value.trim();
  if (!prompt) return;
  
  const outputEl = document.getElementById('analyze-output');
  const spinner = document.getElementById('analyze-spinner');
  outputEl.textContent = '';
  spinner.style.display = 'block';
  
  try {
    const res = await fetch('https://api.anthropic.com/v1/messages', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        model: 'claude-sonnet-4-6',
        max_tokens: 1000,
        messages: [{ role: 'user', content: `You are CodeWatch, a senior code review AI agent. Be direct, technical, and concise.

Task: ${prompt}

${code ? `Code:\n\`\`\`\n${code}\n\`\`\`` : ''}

Respond with clear, actionable analysis. Use code blocks where appropriate.` }]
      })
    });
    
    spinner.style.display = 'none';
    const data = await res.json();
    const text = data.content?.[0]?.text || 'No response';
    
    // Typewriter effect
    outputEl.textContent = '';
    let i = 0;
    const cursor = document.createElement('span');
    cursor.className = 'cursor';
    outputEl.appendChild(cursor);
    
    const typeInterval = setInterval(() => {
      if (i >= text.length) { clearInterval(typeInterval); cursor.remove(); return; }
      cursor.before(text[i++]);
    }, 8);
    
  } catch(err) {
    spinner.style.display = 'none';
    outputEl.textContent = 'Error: ' + err.message;
  }
}

// ---- CHANGELOG ----
async function runChangelog() {
  const commits = document.getElementById('changelog-input').value.trim();
  const version = document.getElementById('version-input').value.trim() || 'v1.0.0';
  if (!commits) return;
  
  const outputEl = document.getElementById('changelog-output');
  outputEl.textContent = 'Generating...';
  
  try {
    const res = await fetch('https://api.anthropic.com/v1/messages', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        model: 'claude-sonnet-4-6',
        max_tokens: 1000,
        messages: [{ role: 'user', content: `Generate a CHANGELOG.md entry in Keep-a-Changelog format for version ${version}.

Commits:
${commits}

Format:
## [${version}] - ${new Date().toISOString().split('T')[0]}

### Breaking Changes
(if any)

### Added
- ...

### Fixed
- ...

### Changed
- ...

### Performance
(if any)

Group the commits properly. Write clear, user-facing descriptions. Return only the changelog markdown, nothing else.` }]
      })
    });
    
    const data = await res.json();
    outputEl.textContent = data.content?.[0]?.text || 'Error generating changelog';
    
  } catch(err) {
    outputEl.textContent = 'Error: ' + err.message;
  }
}

function copyChangelog() {
  navigator.clipboard.writeText(document.getElementById('changelog-output').textContent)
    .then(() => alert('Copied to clipboard!'));
}

// Global run button handler
document.getElementById('run-btn').addEventListener('click', function() {
  const view = state.currentView;
  if (view === 'review') runAnalysis();
  else if (view === 'security') runSecurityScan();
  else if (view === 'analyze') runAnalyze();
  else if (view === 'changelog') runChangelog();
});

// Allow Ctrl+Enter to run
document.addEventListener('keydown', e => {
  if ((e.ctrlKey || e.metaKey) && e.key === 'Enter') {
    document.getElementById('run-btn').click();
  }
});
