<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>CodeWatch — AI Code Review Agent</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@300;400;500;600&family=Syne:wght@400;600;700;800&display=swap" rel="stylesheet">
<style>
:root {
  --bg: #0a0c10;
  --bg2: #0f1117;
  --bg3: #161b24;
  --bg4: #1c2333;
  --border: rgba(99,179,237,0.12);
  --border2: rgba(99,179,237,0.22);
  --accent: #3fb8f0;
  --accent2: #00e5a0;
  --accent3: #f06a3f;
  --text: #e2eaf5;
  --text2: #8899aa;
  --text3: #556677;
  --critical: #ff4757;
  --high: #ff8c00;
  --medium: #f0c040;
  --low: #3fb8f0;
  --info: #00e5a0;
  --mono: 'JetBrains Mono', monospace;
  --sans: 'Syne', sans-serif;
}
* { box-sizing: border-box; margin: 0; padding: 0; }
html, body { height: 100%; background: var(--bg); color: var(--text); font-family: var(--mono); overflow: hidden; }

/* Animated background grid */
body::before {
  content: '';
  position: fixed; inset: 0;
  background-image: 
    linear-gradient(rgba(63,184,240,0.03) 1px, transparent 1px),
    linear-gradient(90deg, rgba(63,184,240,0.03) 1px, transparent 1px);
  background-size: 40px 40px;
  pointer-events: none; z-index: 0;
}
body::after {
  content: '';
  position: fixed; inset: 0;
  background: radial-gradient(ellipse 80% 60% at 20% 0%, rgba(63,184,240,0.06) 0%, transparent 60%),
              radial-gradient(ellipse 60% 40% at 80% 100%, rgba(0,229,160,0.04) 0%, transparent 60%);
  pointer-events: none; z-index: 0;
}

.app { display: flex; height: 100vh; position: relative; z-index: 1; }

/* SIDEBAR */
.sidebar {
  width: 260px; flex-shrink: 0;
  background: var(--bg2);
  border-right: 1px solid var(--border);
  display: flex; flex-direction: column;
  overflow: hidden;
}
.logo {
  padding: 20px 20px 16px;
  border-bottom: 1px solid var(--border);
  display: flex; align-items: center; gap: 10px;
}
.logo-icon {
  width: 32px; height: 32px;
  background: linear-gradient(135deg, var(--accent), var(--accent2));
  border-radius: 8px;
  display: flex; align-items: center; justify-content: center;
  font-size: 16px;
}
.logo-text { font-family: var(--sans); font-weight: 800; font-size: 18px; color: var(--text); letter-spacing: -0.02em; }
.logo-badge { font-size: 9px; color: var(--accent2); letter-spacing: 0.1em; margin-top: 1px; }

.nav { padding: 12px 10px; flex: 1; overflow-y: auto; }
.nav-section-title { font-size: 9px; letter-spacing: 0.15em; color: var(--text3); padding: 8px 10px 4px; }
.nav-item {
  display: flex; align-items: center; gap: 10px;
  padding: 9px 10px; border-radius: 6px; cursor: pointer;
  font-size: 12px; color: var(--text2);
  transition: all 0.15s; margin-bottom: 2px;
}
.nav-item:hover { background: var(--bg3); color: var(--text); }
.nav-item.active { background: rgba(63,184,240,0.1); color: var(--accent); border: 1px solid rgba(63,184,240,0.15); }
.nav-icon { width: 16px; text-align: center; font-size: 14px; }
.nav-badge {
  margin-left: auto; font-size: 10px; padding: 1px 7px;
  background: rgba(255,71,87,0.15); color: var(--critical);
  border-radius: 10px; border: 1px solid rgba(255,71,87,0.2);
}

.sidebar-stats {
  padding: 16px; border-top: 1px solid var(--border);
  display: grid; grid-template-columns: 1fr 1fr; gap: 8px;
}
.stat-mini { background: var(--bg3); border-radius: 6px; padding: 10px; }
.stat-mini-val { font-size: 20px; font-weight: 600; color: var(--text); }
.stat-mini-label { font-size: 9px; color: var(--text3); letter-spacing: 0.08em; margin-top: 2px; }

/* MAIN AREA */
.main { flex: 1; display: flex; flex-direction: column; overflow: hidden; }

/* TOPBAR */
.topbar {
  height: 56px; flex-shrink: 0;
  background: var(--bg2); border-bottom: 1px solid var(--border);
  display: flex; align-items: center; gap: 16px; padding: 0 24px;
}
.topbar-title { font-family: var(--sans); font-weight: 700; font-size: 15px; color: var(--text); }
.topbar-sub { font-size: 11px; color: var(--text3); }
.topbar-actions { margin-left: auto; display: flex; gap: 8px; align-items: center; }
.btn {
  padding: 7px 16px; border-radius: 6px; font-size: 12px; font-family: var(--mono);
  cursor: pointer; border: none; transition: all 0.15s; white-space: nowrap;
}
.btn-ghost { background: transparent; color: var(--text2); border: 1px solid var(--border2); }
.btn-ghost:hover { background: var(--bg3); color: var(--text); }
.btn-primary {
  background: linear-gradient(135deg, var(--accent), #2196f3);
  color: #fff; font-weight: 600;
  box-shadow: 0 0 20px rgba(63,184,240,0.3);
}
.btn-primary:hover { transform: translateY(-1px); box-shadow: 0 4px 24px rgba(63,184,240,0.4); }
.btn-primary:disabled { opacity: 0.5; cursor: not-allowed; transform: none; }
.btn-danger { background: rgba(255,71,87,0.1); color: var(--critical); border: 1px solid rgba(255,71,87,0.2); }
.btn-success { background: rgba(0,229,160,0.1); color: var(--accent2); border: 1px solid rgba(0,229,160,0.2); }

/* CONTENT */
.content { flex: 1; overflow-y: auto; padding: 24px; display: none; }
.content.active { display: block; }

/* PANELS */
.panel-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 16px; }
.panel { background: var(--bg2); border: 1px solid var(--border); border-radius: 10px; overflow: hidden; }
.panel-header {
  padding: 14px 18px; border-bottom: 1px solid var(--border);
  display: flex; align-items: center; gap: 10px;
}
.panel-title { font-family: var(--sans); font-weight: 700; font-size: 13px; color: var(--text); }
.panel-sub { font-size: 11px; color: var(--text3); margin-left: auto; }
.panel-body { padding: 18px; }

/* CODE EDITOR AREA */
.editor-wrap { position: relative; }
.editor-label {
  font-size: 10px; letter-spacing: 0.12em; color: var(--text3);
  padding: 8px 14px 0; font-family: var(--sans);
}
textarea.code-input {
  width: 100%; min-height: 280px;
  background: var(--bg3); border: none; outline: none;
  color: #a8d8ff; font-family: var(--mono); font-size: 12.5px; line-height: 1.7;
  padding: 14px; resize: vertical;
  border-bottom: 1px solid var(--border);
  tab-size: 2;
}
textarea.code-input::placeholder { color: var(--text3); }

.lang-select {
  background: var(--bg3); border: none; color: var(--text2);
  font-family: var(--mono); font-size: 11px; padding: 6px 10px;
  cursor: pointer; outline: none; border-radius: 4px;
  border: 1px solid var(--border);
}
.lang-select option { background: var(--bg3); }

/* RESULTS */
.result-container { min-height: 200px; }
.result-empty {
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  min-height: 200px; color: var(--text3); gap: 10px; font-size: 12px;
}
.result-empty-icon { font-size: 32px; opacity: 0.3; }

.loading-state { display: none; align-items: center; gap: 12px; padding: 20px; }
.loading-state.visible { display: flex; }
.spinner {
  width: 18px; height: 18px; border: 2px solid var(--border2);
  border-top-color: var(--accent); border-radius: 50%;
  animation: spin 0.8s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }

.loading-steps { display: flex; flex-direction: column; gap: 4px; }
.loading-step { font-size: 11px; color: var(--text2); animation: fadeIn 0.4s ease; }
@keyframes fadeIn { from { opacity: 0; transform: translateY(4px); } to { opacity: 1; transform: none; } }

/* ISSUE CARDS */
.issue-list { display: flex; flex-direction: column; gap: 10px; }
.issue-card {
  background: var(--bg3); border-radius: 8px;
  border-left: 3px solid transparent; padding: 14px 16px;
  animation: slideIn 0.3s ease;
}
@keyframes slideIn { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: none; } }
.issue-card.critical { border-left-color: var(--critical); }
.issue-card.high { border-left-color: var(--high); }
.issue-card.medium { border-left-color: var(--medium); }
.issue-card.low { border-left-color: var(--low); }
.issue-card.info { border-left-color: var(--info); }

.issue-header { display: flex; align-items: center; gap: 8px; margin-bottom: 8px; }
.severity-badge {
  font-size: 9px; font-weight: 600; letter-spacing: 0.1em;
  padding: 2px 8px; border-radius: 3px;
}
.badge-critical { background: rgba(255,71,87,0.15); color: var(--critical); border: 1px solid rgba(255,71,87,0.25); }
.badge-high { background: rgba(255,140,0,0.15); color: var(--high); border: 1px solid rgba(255,140,0,0.25); }
.badge-medium { background: rgba(240,192,64,0.15); color: var(--medium); border: 1px solid rgba(240,192,64,0.25); }
.badge-low { background: rgba(63,184,240,0.15); color: var(--low); border: 1px solid rgba(63,184,240,0.25); }
.badge-info { background: rgba(0,229,160,0.15); color: var(--info); border: 1px solid rgba(0,229,160,0.25); }

.issue-title { font-size: 13px; font-weight: 500; color: var(--text); }
.issue-location { font-size: 10px; color: var(--text3); margin-left: auto; font-family: var(--mono); }
.issue-desc { font-size: 12px; color: var(--text2); line-height: 1.6; margin-bottom: 10px; }
.issue-fix { 
  background: var(--bg4); border-radius: 6px; padding: 10px 12px;
  font-size: 11px; font-family: var(--mono); color: #a8d8ff; line-height: 1.6;
  border: 1px solid var(--border);
}
.issue-fix-label { font-size: 9px; color: var(--accent2); letter-spacing: 0.1em; margin-bottom: 6px; }

/* SUMMARY BAR */
.summary-bar {
  display: flex; gap: 12px; padding: 14px 18px;
  background: var(--bg3); border-bottom: 1px solid var(--border);
  flex-wrap: wrap; align-items: center;
}
.summary-item { display: flex; align-items: center; gap: 6px; font-size: 12px; }
.summary-dot { width: 8px; height: 8px; border-radius: 50%; }
.verdict {
  margin-left: auto; font-size: 11px; font-weight: 600; letter-spacing: 0.08em;
  padding: 4px 14px; border-radius: 4px;
}
.verdict-approve { background: rgba(0,229,160,0.1); color: var(--accent2); border: 1px solid rgba(0,229,160,0.2); }
.verdict-reject { background: rgba(255,71,87,0.1); color: var(--critical); border: 1px solid rgba(255,71,87,0.2); }
.verdict-discuss { background: rgba(240,192,64,0.1); color: var(--medium); border: 1px solid rgba(240,192,64,0.2); }

/* SECURITY TAB */
.owasp-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 10px; }
.owasp-card {
  background: var(--bg3); border: 1px solid var(--border);
  border-radius: 8px; padding: 14px; cursor: pointer;
  transition: all 0.15s;
}
.owasp-card:hover { border-color: var(--border2); background: var(--bg4); }
.owasp-card.detected { border-color: rgba(255,71,87,0.3); background: rgba(255,71,87,0.05); }
.owasp-card.clean { border-color: rgba(0,229,160,0.2); background: rgba(0,229,160,0.03); }
.owasp-num { font-size: 10px; color: var(--text3); letter-spacing: 0.1em; margin-bottom: 4px; }
.owasp-name { font-size: 12px; font-weight: 500; color: var(--text); margin-bottom: 6px; }
.owasp-status { font-size: 10px; }
.owasp-status.detected { color: var(--critical); }
.owasp-status.clean { color: var(--accent2); }

/* AGENT CONFIG TAB */
.config-section { margin-bottom: 20px; }
.config-label { font-size: 10px; letter-spacing: 0.12em; color: var(--text3); margin-bottom: 8px; font-family: var(--sans); }
.config-file {
  background: var(--bg3); border: 1px solid var(--border);
  border-radius: 8px; overflow: hidden;
}
.config-file-header {
  padding: 10px 14px; background: var(--bg4);
  border-bottom: 1px solid var(--border);
  display: flex; align-items: center; gap: 8px;
  font-size: 11px; color: var(--accent);
}
.config-file-body {
  padding: 14px; font-size: 12px; font-family: var(--mono);
  color: var(--text2); line-height: 1.7; white-space: pre;
  max-height: 200px; overflow-y: auto;
}

/* HISTORY TAB */
.history-item {
  background: var(--bg3); border: 1px solid var(--border);
  border-radius: 8px; padding: 14px 16px; margin-bottom: 10px;
  display: flex; align-items: center; gap: 14px; cursor: pointer;
  transition: all 0.15s;
}
.history-item:hover { border-color: var(--border2); }
.history-dot { width: 10px; height: 10px; border-radius: 50%; flex-shrink: 0; }
.history-info { flex: 1; }
.history-title { font-size: 13px; color: var(--text); margin-bottom: 3px; }
.history-meta { font-size: 11px; color: var(--text3); }
.history-score {
  font-size: 20px; font-weight: 600;
  font-family: var(--sans);
}

/* ANALYZE FULL TAB */
.prompt-area {
  background: var(--bg3); border: 1px solid var(--border);
  border-radius: 8px; padding: 14px;
  display: flex; gap: 10px; margin-bottom: 16px;
}
textarea.prompt-input {
  flex: 1; background: transparent; border: none; outline: none;
  color: var(--text); font-family: var(--mono); font-size: 12px;
  resize: none; min-height: 60px; line-height: 1.6;
}
textarea.prompt-input::placeholder { color: var(--text3); }

/* Scrollbar */
::-webkit-scrollbar { width: 4px; }
::-webkit-scrollbar-track { background: transparent; }
::-webkit-scrollbar-thumb { background: var(--border2); border-radius: 4px; }

/* STREAMING TEXT */
.stream-output {
  font-size: 13px; color: var(--text); line-height: 1.8;
  white-space: pre-wrap; font-family: var(--mono);
  background: var(--bg3); border-radius: 8px; padding: 18px;
  border: 1px solid var(--border); min-height: 100px;
}
.cursor { display: inline-block; width: 2px; height: 14px; background: var(--accent); animation: blink 1s step-end infinite; vertical-align: middle; margin-left: 2px; }
@keyframes blink { 50% { opacity: 0; } }

/* Scan progress */
.scan-bar { height: 3px; background: var(--border); border-radius: 2px; margin-bottom: 16px; overflow: hidden; }
.scan-bar-fill { height: 100%; background: linear-gradient(90deg, var(--accent), var(--accent2)); border-radius: 2px; width: 0%; transition: width 0.4s ease; }

.metric-row { display: flex; gap: 12px; margin-bottom: 16px; }
.metric-card {
  flex: 1; background: var(--bg3); border: 1px solid var(--border);
  border-radius: 8px; padding: 14px; text-align: center;
}
.metric-val { font-family: var(--sans); font-size: 28px; font-weight: 700; color: var(--text); }
.metric-label { font-size: 10px; color: var(--text3); letter-spacing: 0.1em; margin-top: 4px; }
.metric-card.good .metric-val { color: var(--accent2); }
.metric-card.warn .metric-val { color: var(--medium); }
.metric-card.bad .metric-val { color: var(--critical); }

/* Tabs inside content */
.inner-tabs { display: flex; gap: 2px; margin-bottom: 16px; border-bottom: 1px solid var(--border); }
.inner-tab {
  padding: 8px 16px; font-size: 12px; color: var(--text3);
  cursor: pointer; border-bottom: 2px solid transparent;
  transition: all 0.15s; margin-bottom: -1px;
}
.inner-tab:hover { color: var(--text); }
.inner-tab.active { color: var(--accent); border-bottom-color: var(--accent); }
.inner-content { display: none; }
.inner-content.active { display: block; }

/* Notification dot */
.notif { width: 6px; height: 6px; border-radius: 50%; background: var(--critical); margin-left: auto; }

/* Pulse animation for live */
.live-badge { 
  display: inline-flex; align-items: center; gap: 5px;
  font-size: 10px; color: var(--accent2); letter-spacing: 0.05em;
  padding: 3px 10px; background: rgba(0,229,160,0.08);
  border: 1px solid rgba(0,229,160,0.2); border-radius: 12px;
}
.live-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--accent2); animation: pulse 2s infinite; }
@keyframes pulse { 0%,100% { opacity: 1; transform: scale(1); } 50% { opacity: 0.5; transform: scale(0.8); } }

.tag { display: inline-block; font-size: 10px; padding: 2px 8px; border-radius: 3px; margin: 2px; }
.tag-blue { background: rgba(63,184,240,0.1); color: var(--low); border: 1px solid rgba(63,184,240,0.2); }
.tag-green { background: rgba(0,229,160,0.1); color: var(--info); border: 1px solid rgba(0,229,160,0.2); }

.divider { height: 1px; background: var(--border); margin: 16px 0; }
</style>
</head>
<body>

<div class="app">
  <!-- SIDEBAR -->
  <div class="sidebar">
    <div class="logo">
      <div class="logo-icon">⚡</div>
      <div>
        <div class="logo-text">CodeWatch</div>
        <div class="logo-badge">GITAGENT POWERED</div>
      </div>
    </div>
    <div class="nav">
      <div class="nav-section-title">WORKSPACE</div>
      <div class="nav-item active" onclick="switchView('review')">
        <span class="nav-icon">🔍</span> PR Review
      </div>
      <div class="nav-item" onclick="switchView('security')">
        <span class="nav-icon">🛡</span> Security Scan
        <span class="nav-badge" id="vuln-count">0</span>
      </div>
      <div class="nav-item" onclick="switchView('analyze')">
        <span class="nav-icon">💬</span> AI Analyze
      </div>
      <div class="nav-item" onclick="switchView('changelog')">
        <span class="nav-icon">📋</span> Changelog Gen
      </div>
      <div class="nav-section-title" style="margin-top:12px">AGENT</div>
      <div class="nav-item" onclick="switchView('config')">
        <span class="nav-icon">⚙️</span> Agent Config
      </div>
      <div class="nav-item" onclick="switchView('history')">
        <span class="nav-icon">📁</span> History
        <div class="notif" id="history-notif" style="display:none"></div>
      </div>
    </div>
    <div class="sidebar-stats">
      <div class="stat-mini">
        <div class="stat-mini-val" id="stat-reviews">0</div>
        <div class="stat-mini-label">REVIEWS</div>
      </div>
      <div class="stat-mini">
        <div class="stat-mini-val" id="stat-issues">0</div>
        <div class="stat-mini-label">ISSUES</div>
      </div>
      <div class="stat-mini">
        <div class="stat-mini-val" id="stat-critical">0</div>
        <div class="stat-mini-label">CRITICAL</div>
      </div>
      <div class="stat-mini">
        <div class="stat-mini-val" id="stat-score">—</div>
        <div class="stat-mini-label">SCORE</div>
      </div>
    </div>
  </div>

  <!-- MAIN -->
  <div class="main">

    <!-- TOPBAR -->
    <div class="topbar">
      <div>
        <div class="topbar-title" id="view-title">PR Code Review</div>
        <div class="topbar-sub" id="view-sub">Paste code to analyze with AI</div>
      </div>
      <div class="live-badge"><div class="live-dot"></div>CLAUDE claude-sonnet-4-6</div>
      <div class="topbar-actions">
        <select class="lang-select" id="lang-select">
          <option value="javascript">JavaScript</option>
          <option value="python">Python</option>
          <option value="typescript">TypeScript</option>
          <option value="go">Go</option>
          <option value="rust">Rust</option>
          <option value="java">Java</option>
          <option value="php">PHP</option>
          <option value="ruby">Ruby</option>
          <option value="sql">SQL</option>
          <option value="bash">Bash</option>
        </select>
        <button class="btn btn-ghost" onclick="clearAll()">Clear</button>
        <button class="btn btn-primary" id="run-btn" onclick="runAnalysis()">▶ Run Review</button>
      </div>
    </div>

    <!-- PR REVIEW VIEW -->
    <div class="content active" id="view-review">
      <div class="panel-grid" style="grid-template-columns: 1fr 1fr; height: calc(100vh - 100px);">
        <!-- Input -->
        <div class="panel" style="display:flex; flex-direction:column;">
          <div class="panel-header">
            <span style="color:var(--accent)">❮❯</span>
            <span class="panel-title">Code Input</span>
            <span class="panel-sub">Paste your code or diff</span>
          </div>
          <div style="flex:1; display:flex; flex-direction:column; overflow:hidden;">
            <textarea class="code-input" id="code-input" style="flex:1; min-height:unset;" placeholder="// Paste your code here for review...
// Supports diffs, functions, classes, files
//
// Example:
function authenticate(user, pass) {
  const query = 'SELECT * FROM users WHERE user=\'' + user + '\'';
  return db.query(query);
}"></textarea>
            <div style="padding: 10px 14px; background: var(--bg3); border-top: 1px solid var(--border); display:flex; gap:8px; align-items:center;">
              <span style="font-size:11px; color:var(--text3)">Quick load:</span>
              <button class="btn btn-ghost" style="padding:4px 10px; font-size:11px" onclick="loadExample('sqli')">SQL Injection</button>
              <button class="btn btn-ghost" style="padding:4px 10px; font-size:11px" onclick="loadExample('xss')">XSS Bug</button>
              <button class="btn btn-ghost" style="padding:4px 10px; font-size:11px" onclick="loadExample('secret')">Hardcoded Secret</button>
              <button class="btn btn-ghost" style="padding:4px 10px; font-size:11px" onclick="loadExample('clean')">Clean Code</button>
            </div>
          </div>
        </div>

        <!-- Output -->
        <div class="panel" style="display:flex; flex-direction:column; overflow:hidden;">
          <div class="panel-header">
            <span style="color:var(--accent2)">◈</span>
            <span class="panel-title">AI Review Results</span>
            <span class="panel-sub" id="result-time"></span>
          </div>

